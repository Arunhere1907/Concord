# ==============================================================================
# CONCORD26 - FIFA WORLD CUP 2026 STADIUM OPERATIONS PLATFORM
# Environment Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# AI CONFIGURATION (Required for full features)
# ------------------------------------------------------------------------------

# GEMINI_API_KEY: Required for Gemini AI-powered features (incident triage, fan concierge, command copilot).
# Get a free API key from: https://aistudio.google.com/apikey
# Without this key, the app will use built-in rule-based fallbacks.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION (Optional - Future Supabase Integration)
# ------------------------------------------------------------------------------

# Supabase Project URL (example: https://abcdefghij.supabase.co)
# SUPABASE_URL=""

# Supabase Anonymous Key (safe to expose in client-side code)
# SUPABASE_ANON_KEY=""

# Supabase Service Role Key (server-side only, never expose to client)
# SUPABASE_SERVICE_KEY=""

# ------------------------------------------------------------------------------
# APPLICATION CONFIGURATION (Optional)
# ------------------------------------------------------------------------------

# Application environment: development | production | test
NODE_ENV="development"

# Port for local development server (default: 3000)
PORT=3000

# ------------------------------------------------------------------------------
# SECURITY & RATE LIMITING (Production)
# ------------------------------------------------------------------------------

# Redis connection string for distributed rate limiting (optional)
# REDIS_URL=""

# Upstash Redis REST URL (for serverless rate limiting)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ------------------------------------------------------------------------------
# MONITORING & ANALYTICS (Production)
# ------------------------------------------------------------------------------

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=""

# Vercel Analytics (auto-configured in Vercel deployment)
# No manual configuration needed

# ------------------------------------------------------------------------------
# NOTES
# ------------------------------------------------------------------------------
# 
# 1. Never commit this file with real values to version control
# 2. Copy this file to .env for local development: cp .env.example .env
# 3. In production (Vercel), set these in Project Settings > Environment Variables
# 4. See SECURITY.md for detailed security guidelines
#
# ==============================================================================

